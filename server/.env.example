# 服务器端口
PORT=3000

# 审核引擎选择: local | aliyun | baidu | llm
AUDIT_PROVIDER=local

# 百度智能云审核配置
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# 阿里云内容安全配置
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_ENDPOINT=green-international.cn-shanghai.aliyuncs.com

# 大模型审核配置
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
